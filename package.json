{
  "name": "language-tracker",
  "version": "1.0.0",
  "description": "Language learning tracking application with comprehensive E2E testing",
  "scripts": {
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:headed": "playwright test tests/e2e --headed",
    "test:user-stories": "playwright test tests/user_stories",
    "test:user-stories:fast": "playwright test tests/user_stories/fast",
    "test:user-stories:realistic": "playwright test tests/user_stories/realistic",
    "test:all-e2e": "playwright test tests/e2e tests/user_stories",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:install": "playwright install chromium",
    "start": "python app.py",
    "start:dev": "FLASK_ENV=development python app.py",
    "start:test": "FLASK_ENV=testing DATABASE_PATH=test_langtrak.db PORT=5001 python app.py",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:test": "echo 'Flask server - no build required'",
    "dev": "webpack serve --mode development --open",
    "dev:setup": "python -m pytest features/authentication/tests/unit/ --verbose"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.4",
    "playwright": "^1.56.1",
    "postcss-loader": "^8.2.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4"
  },
  "file_id": "d02172d6-9796-4dc4-819f-2b80e25dfd5b"
}
